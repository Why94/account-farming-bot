# ============================================
#  Konfigurasi Account Farming Bot v2.0
#  Copy file ini jadi ".env" lalu isi nilainya
# ============================================

# ===== General =====
PASSWORD_DEFAULT=AmanJaya123!@#
MAX_WORKERS=5
JUMLAH_AKUN=20
MAX_RETRIES=3
BASE_RETRY_DELAY=5.0
MAX_RETRY_DELAY=60.0

# ===== Target =====
TARGET_URL=https://example.com/register

# ===== Proxy (Webshare) =====
USE_PROXY_API=true
PROXY_PROVIDER=webshare
WEBSHARE_TOKEN=GANTI_DENGAN_TOKEN_WEBSHARE_ANDA

# ===== Residential Proxy (Optional, for anti-detect) =====
# brightdata, smartproxy, iproyal
RESIDENTIAL_PROXY_PROVIDER=
RESIDENTIAL_PROXY_TOKEN=

# ===== Rate Limiting per IP =====
RATE_LIMIT_PER_IP=3
RATE_LIMIT_WINDOW=3600

# ===== Email Providers =====
USE_MAIL_TM=true
USE_1SEC_MAIL=true
USE_TEMP_MAIL=false
USE_GUERRILLA_MAIL=false
FALLBACK_DOMAIN=domainkamu.my.id

# ===== Browser =====
HEADLESS=true
USE_STEALTH=true
INJECT_FINGERPRINT=true
MOUSE_SIMULATION=true
KEYBOARD_SIMULATION=true
WEBRTC_BLOCK=true
PERMISSIONS_RANDOM=true
GEO_SPOOF=true
CANVAS_NOISE=true

# ===== CAPTCHA Solver (CapSolver) =====
USE_CAPTCHA=true
CAPSOLVER_API_KEY=GANTI_DENGAN_API_KEY_CAPSOLVER_ANDA

# ===== Database (PostgreSQL) =====
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:pass@host:port/dbname

# ===== Notifikasi Telegram =====
NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Notifikasi Discord =====
NOTIFY_DISCORD=false
DISCORD_WEBHOOK_URL=

# ===== Generic Webhook =====
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# ===== Ban Rate Alert =====
BAN_RATE_THRESHOLD=50

# ===== Monitoring =====
SCREENSHOT_ON_ERROR=true
SCREENSHOT_DIR=./screenshots
ENABLE_DASHBOARD=true
DASHBOARD_PORT=8080
LOG_ROTATION=daily
ENABLE_PROGRESS_BAR=true

# ===== Export =====
EXPORT_CSV=true
EXPORT_EXCEL=true
EXPORT_DIR=./exports

# ===== Batch Mode =====
ENABLE_BATCH=true
BATCH_SIZE=10
BATCH_DELAY=60
