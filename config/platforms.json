{
  "description": "Multi-platform configuration for Account Farming Bot v2.0",
  "platforms": [
    {
      "name": "runway",
      "register_url": "https://www.runwayml.com/register",
      "category": "ai",
      "email_selector": "input[name='email'], input[type='email']",
      "password_selector": "input[name='password'], input[type='password']",
      "submit_selector": "button[type='submit'], button:has-text('Sign Up'), button:has-text('Create Account')",
      "success_indicators": [
        "verify",
        "verifikasi",
        "confirm",
        "konfirmasi",
        "check your email",
        "cek email",
        "welcome",
        "selamat datang",
        "success",
        "berhasil",
        "registered",
        "terdaftar",
        "almost there",
        "hampir selesai"
      ],
      "error_indicators": [
        "already exists",
        "sudah terdaftar",
        "already registered",
        "email taken",
        "email digunakan",
        "duplicate",
        "captcha failed",
        "captcha invalid",
        "recaptcha failed",
        "rate limit",
        "terlalu banyak",
        "too many requests",
        "invalid email",
        "email tidak valid",
        "blocked",
        "diblokir"
      ]
    },
    {
      "name": "leonardo",
      "register_url": "https://app.leonardo.ai/auth/login",
      "category": "ai",
      "email_selector": "input[type='email']",
      "password_selector": "input[type='password']",
      "submit_selector": "button[type='submit'], button:has-text('Continue with Email'), button:has-text('Sign Up')",
      "success_indicators": [
        "verify",
        "welcome",
        "success",
        "registered",
        "check your email",
        "confirm your email",
        "almost there"
      ],
      "error_indicators": [
        "already exists",
        "already registered",
        "email taken",
        "duplicate",
        "captcha failed",
        "rate limit",
        "too many requests",
        "invalid email",
        "blocked",
        "suspended"
      ],
      "notes": "SSO-heavy (Google/Apple/Microsoft). Email signup ada tapi butuh verifikasi + anti-bot kuat. Uji dengan HEADLESS=false dulu."
    },
    {
      "name": "kling",
      "register_url": "https://klingai.com",
      "category": "ai",
      "email_selector": "input[type='email']",
      "password_selector": "input[type='password']",
      "submit_selector": "button[type='submit'], button:has-text('Sign Up'), button:has-text('Create')",
      "success_indicators": [
        "verify",
